menu "VoidLink Adapter"

config VOIDLINK_WIFI_SSID
    string "Wi-Fi SSID"
    default ""
    help
        Wi-Fi network that the T-Dongle uses as the upstream deck/control network.

config VOIDLINK_WIFI_PASSWORD
    string "Wi-Fi password"
    default ""
    help
        Password for the configured Wi-Fi network. Leave empty for an open network.

config VOIDLINK_AUTO_RECONNECT
    bool "Reconnect Wi-Fi automatically"
    default y
    help
        Keep trying to reconnect when the upstream Wi-Fi drops.

endmenu
